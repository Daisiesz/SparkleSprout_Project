{
  "name": "sparklesprout-functions",
  "description": "Firebase Functions for SparkleSprout",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@genkit-ai/core": "^0.10.0",
    "@genkit-ai/firebase": "^0.10.0",
    "@genkit-ai/retriever": "^0.10.0",
    "@google-cloud/vertexai": "^1.0.0",
    "firebase-admin": "^11.11.0",
    "firebase-functions": "^4.5.0",
    "genai": "latest"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
